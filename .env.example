# stockhub-mcp environment configuration
# Copy to .env and adjust as needed. All values have sensible defaults.
# 复制为 .env 后按需修改，所有配置项均有默认值。

# Maximum cache entries, FIFO eviction when full | 最大缓存条目数，满时按 FIFO 淘汰
# CACHE_MAX_SIZE=100

# Tushare Pro token for enhanced A-share data | 图说 Pro Token，用于增强 A 股数据（可选）
# TUSHARE_TOKEN=

# HTTP request timeout in seconds | HTTP 请求超时时间（秒）
# REQUEST_TIMEOUT=15

# Maximum retry attempts per data source | 每个数据源的最大重试次数
# MAX_RETRIES=2

# Cooldown period (seconds) before retrying a degraded source | 降级数据源的冷却时间（秒）
# CIRCUIT_BREAKER_COOLDOWN=300

# Rolling window (seconds) for counting failures | 故障计数的滑动时间窗口（秒）
# CIRCUIT_BREAKER_FAILURE_WINDOW=60
